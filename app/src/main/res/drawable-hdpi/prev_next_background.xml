<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" >
        <shape>
            <gradient
                android:centerColor="#d8e55f"
        		android:endColor="#D9E849"
       			android:startColor="#dce67a"              
                android:angle="270" />
            <corners
                android:radius="15dp" />
           
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
<!-- <solid android:color="#fbf5b5" /> -->
           <gradient
		        android:angle="270"
		        android:centerColor="#70323234"
		        android:endColor="#701a1a1a"
		        android:startColor="#704e4d4e" />
            <corners
                android:radius="15dp" />
           
        </shape>
    </item>
</selector>